# Copy this file to .env and fill in your values

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED — the api and sync containers will refuse to start without this.
SECRET_KEY=

# ── Garmin credentials (legacy / single-user) ─────────────────────────────────
# These are auto-migrated to encrypted DB credentials on first run and can be
# removed afterwards. In multi-user mode, each user sets credentials via the UI.
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=garmin
POSTGRES_USER=garmin
POSTGRES_PASSWORD=changeme

# ── Sync behaviour ────────────────────────────────────────────────────────────
# How many days to backfill on first run (3650 = ~10 years)
SYNC_BACKFILL_DAYS=3650

# How often to re-sync in seconds (3600 = every hour)
SYNC_INTERVAL_SECONDS=3600
